# =============================================================================
# 🔑 OPENROUTER - Authentification
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# 🎯 QWEN3.6+ - Paramètres d'optimisation
# =============================================================================

# Modèle par défaut pour les tâches standards
QWEN_DEFAULT_MODEL=qwen/qwen3.6-plus

# Modèle pour les sous-tâches rapides / formatage (économique)
QWEN_FLASH_MODEL=qwen/qwen-flash

# Modèle pour l'architecture complexe / planification lourde
QWEN_MAX_MODEL=qwen/qwen-max

# Limite de contexte par session (en tokens) - pour les alertes 70%/90%
QWEN_CONTEXT_LIMIT=1000000

# Seuil d'alerte préventive (en % du contexte)
QWEN_ALERT_WARNING=70

# Seuil d'alerte critique (en % du contexte)
QWEN_ALERT_CRITICAL=90

# =============================================================================
# ⚙️ COMPORTEMENT AGENT - Options avancées
# =============================================================================

# Activer le mode planification forcée (95% confiance avant exécution)
# Valeurs: true | false
QWEN_PLAN_MODE=true

# Compactage manuel déclenché à X% du contexte (au lieu de l'auto à 95%)
QWEN_MANUAL_COMPACT_THRESHOLD=60

# Timeout du cache prefix en minutes (OpenRouter/Qwen ~5 min)
QWEN_CACHE_TIMEOUT_MIN=5

# Nombre max de sous-agents parallèles
QWEN_MAX_SUBAGENTS=2

# =============================================================================
# 🕒 OFF-PEAK SCHEDULING - Optimisation coût/dispo
# =============================================================================

# Heure de début des off-peak hours (format 24h, timezone locale)
QWEN_OFFPEAK_START_HOUR=20

# Activer le report automatique des tâches lourdes en peak hours
QWEN_ENABLE_OFFPEAK_SCHEDULING=false

# =============================================================================
# 📁 FICHIERS DE RÉFÉRENCE - Paths pour les hacks 10 & 18
# =============================================================================

# Chemin vers le fichier système prompt léger (<200 lignes)
QWEN_SYS_PROMPT_FILE=.qwen_sys.md

# Chemin vers le fichier de vérité persistante (décisions, pas logs)
QWEN_PROGRESS_FILE=qwen_progress.md

# =============================================================================
# 🐛 DEBUG & LOGGING
# =============================================================================

# Niveau de log : DEBUG | INFO | WARNING | ERROR | CRITICAL
QWEN_LOG_LEVEL=INFO

# Activer l'affichage détaillé des tokens usage dans la console
QWEN_DEBUG_TOKEN_USAGE=false
